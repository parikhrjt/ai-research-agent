# Application
APP_NAME=AI Research Agent
APP_ENV=development
LOG_LEVEL=INFO

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000

# Streamlit
STREAMLIT_PORT=8501

# Vector store: pgvector | chroma
VECTOR_STORE=pgvector

# PostgreSQL (pgvector)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=research
POSTGRES_PASSWORD=research
POSTGRES_DB=research_agent
DATABASE_URL=postgresql://research:research@localhost:5432/research_agent

# ChromaDB (alternative vector store)
CHROMA_PERSIST_DIR=./data/chroma

# Embeddings (local, free)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=150

# RAG
RETRIEVAL_TOP_K=5
RETRIEVAL_SCORE_THRESHOLD=0.3

# LLM provider: ollama | openai
LLM_PROVIDER=ollama

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# OpenAI (optional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Upload limits
MAX_UPLOAD_SIZE_MB=25
ALLOWED_EXTENSIONS=pdf,txt,md,markdown,csv
